# ===== LokmaGo Admin/Restoran paneli sozlamalari =====
# Bu faylni .env deb nusxalang:  cp .env.example .env

# Backend API manzili
VITE_API_URL=http://localhost:4000/api

# Socket.IO manzili (yangi buyurtmalarni real-time eshitish)
VITE_SOCKET_URL=http://localhost:4000

# Ushbu panel qaysi restoranga tegishli (seed'dan keyin restoran _id sini qo'ying)
VITE_RESTAURANT_ID=demo
